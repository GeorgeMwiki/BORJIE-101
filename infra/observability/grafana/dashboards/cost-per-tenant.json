{
  "annotations": { "list": [] },
  "description": "LLM token cost per tenant × tier — supports cost-attribution + tier-pricing decisions.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "timeseries",
      "title": "AI cost USD/h per tenant",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        {
          "expr": "rate(ai_cost_usd_per_tenant[1h])",
          "legendFormat": "{{tenant_id}} ({{tier}})",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] }
    },
    {
      "type": "barchart",
      "title": "Cost share by tier (24h)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 10 },
      "id": 2,
      "targets": [
        {
          "expr": "sum by (tier) (increase(ai_cost_usd_per_tenant[24h]))",
          "legendFormat": "{{tier}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] }
    },
    {
      "type": "table",
      "title": "Top-10 tenants by 24h cost",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 10 },
      "id": 3,
      "targets": [
        {
          "expr": "topk(10, sum by (tenant_id, tier) (increase(ai_cost_usd_per_tenant[24h])))",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tokens/min by model",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 20 },
      "id": 4,
      "targets": [
        {
          "expr": "sum by (model) (rate(ai_tokens_total[1m]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["cost", "ai", "tenant", "f7"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": false, "text": "Prometheus", "value": "prometheus" }
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Cost per Tenant",
  "uid": "cost-per-tenant",
  "version": 1,
  "weekStart": ""
}
