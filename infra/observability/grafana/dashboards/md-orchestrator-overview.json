  },
  "description": "Central-command MD orchestrator — request rate, error rate, latency percentiles, hook-chain decisions.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "timeseries",
      "title": "Request rate (req/s)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        {
          "expr": "sum(rate(kernel_requests_total[1m]))",
          "legendFormat": "all",
          "refId": "A"
        },
        {
          "expr": "sum by (sub_md) (rate(kernel_requests_total[1m]))",
          "legendFormat": "{{sub_md}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Error rate (errors/s)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(kernel_errors_total[5m]))",
          "legendFormat": "errors",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.005 },
              { "color": "red", "value": 0.01 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Latency percentiles (ms)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(kernel_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(kernel_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(kernel_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "type": "piechart",
      "title": "Hook-chain decision distribution",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 17 },
      "id": 4,
      "targets": [
        {
          "expr": "sum by (decision) (rate(kernel_hook_decision_total[5m]))",
          "legendFormat": "{{decision}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut"
      }
    },
    {
      "type": "stat",
      "title": "Active sub-MDs",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 17 },
      "id": 5,
      "targets": [
        {
          "expr": "count(count by (sub_md) (kernel_requests_total))",
          "legendFormat": "active",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["md-orchestrator", "central-command", "f7"],
