{
  "annotations": { "list": [] },
  "description": "Per sub-MD SLO status, canary stage, breach counts.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "table",
      "title": "Per sub-MD SLO status",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 11, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        {
          "expr": "sub_md_slo_status",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true },
            "indexByName": {
              "sub_md": 0,
              "canary_stage": 1,
              "status": 2,
              "breach_count": 3
            }
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "SLO breach count over time",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 11 },
      "id": 2,
      "targets": [
        {
          "expr": "sum by (sub_md) (increase(sub_md_slo_breach_total[1h]))",
          "legendFormat": "{{sub_md}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Sub-MDs in breach",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 11 },
      "id": 3,
      "targets": [
        {
          "expr": "count(sub_md_slo_status{status=\"breach\"})",
          "legendFormat": "in_breach",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "barchart",
      "title": "Canary-stage histogram",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 20 },
      "id": 4,
      "targets": [
        {
          "expr": "count by (canary_stage) (sub_md_slo_status)",
          "legendFormat": "{{canary_stage}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["sub-md", "slo", "f7"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": false, "text": "Prometheus", "value": "prometheus" }
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Sub-MD SLOs",
  "uid": "sub-md-slos",
  "version": 1,
  "weekStart": ""
}
