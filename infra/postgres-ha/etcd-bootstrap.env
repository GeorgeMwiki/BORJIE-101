# =============================================================================
# etcd 3-node cluster bootstrap (consumed by docker-compose.ha.yml)
# =============================================================================
# Patroni uses this etcd cluster as the DCS (distributed configuration store)
# for leader election. Raft quorum = 2/3, tolerating one node loss.
#
# Each etcd container reads its own ETCD_NAME and ETCD_ADVERTISE_* envs;
# this file defines the SHARED cluster topology.
# =============================================================================

ETCD_INITIAL_CLUSTER=etcd-1=http://etcd-1:2380,etcd-2=http://etcd-2:2380,etcd-3=http://etcd-3:2380
ETCD_INITIAL_CLUSTER_TOKEN=borjie-pgha-cluster
ETCD_INITIAL_CLUSTER_STATE=new
ETCD_ENABLE_V2=false
ETCD_AUTO_COMPACTION_MODE=periodic
ETCD_AUTO_COMPACTION_RETENTION=1h
ETCD_QUOTA_BACKEND_BYTES=2147483648
