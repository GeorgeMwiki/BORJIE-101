# =============================================================================
# === [REQUIRED] SIGNING SECRETS FOR CERTS ===================================
# =============================================================================
# Generate via `pnpm gen-secrets`.

AGENT_CERT_SIGNING_SECRET=
# Audio-evidence signer (LITFIN audio-logics) — REQUIRED in production. When unset
