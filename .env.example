# guard in packages/audio-logics-litfin/src/evidence-chain/signer.ts THROWS.
AUDIO_EVIDENCE_SIGNING_KEY_ID=                 # e.g. 'audio-evidence-prod-2026Q2'
AUDIO_EVIDENCE_SIGNING_KEY_SECRET=             # openssl rand -hex 48
# C2PA content-provenance signer — REQUIRED in production. Same prod-guard
# pattern as the audio evidence key above; see packages/content-studio/src/c2pa/signer.ts.
