# =============================================================================
# BORJIE Environment Configuration — Complete Template
# =============================================================================
# Refactored 2026-05-27 (Mr. Mwikila) — see Docs/QA/PROD_ENV_READINESS_2026_05_27.md
#
# RECOMMENDED — one-command bootstrap (creates Supabase project, generates
# secrets, applies migrations, seeds the dev tenant):
#
#   export SUPABASE_ACCESS_TOKEN=sbp_xxx     # from supabase.com/dashboard/account/tokens
#   pnpm setup-env
#
# Manual setup (if `pnpm setup-env` is not an option):
#   cp .env.example .env.local
#   pnpm gen-secrets --write                  # populate the TODO_BORJIE_* secrets
#   # then hand-fill the TODO_BORJIE_SUPABASE_* values from your project
#
# Markers used in this template:
#   TODO_BORJIE_*       — project-specific value; `pnpm setup-env` replaces these
#   TODO_PRELAUNCH:     — gate not yet wired in code; tracked in audit doc
#   [PRODUCTION-ONLY]   — MUST be set in production; safe to leave blank in dev
#   [DEV-ONLY]          — only for local dev / live-test; NEVER set in production
#   (empty value)       — optional; left blank for explicit opt-in
#   (default value)     — sensible default; safe to leave as-is in dev
#
# Operator note (N4, 2026-05-29):
#   Optional keys may safely ship as `KEY=` (empty value) in .env / .env.local.
#   The api-gateway env validator
#   (services/api-gateway/src/config/validate-env.ts) treats empty strings as
#   unset for every optional field, so blank placeholders document the key
#   list without crashing boot. To populate a `TODO_BORJIE_GENERATE_*` slot,
#   run `pnpm gen-secrets --write` or `openssl rand -base64 48` manually.
#   Dev sentinels accepted alongside real values:
#     OCR_PROVIDER=mock                  — no real OCR backend wired
#     GEPG_PSP_MODE=true|false           — GePG running in mock mode
#
# Sections within each group are sorted alphabetically.
#
# Runbook for the bootstrap script: Docs/RUNBOOKS/supabase-bootstrap.md
# First-time production live test:  Docs/SUPABASE_LIVE_TEST.md
# Master docs index:                Docs/INDEX.md
# Secret-rotation runbook:          Docs/RUNBOOKS/encryption-at-rest-key-rotation.md
# Default rotation cadence:         90 days for app secrets, 365 days for
#                                   provider API keys (or per-provider policy)
#
# Severity tiers:
#   [REQUIRED]    — App will not start without these in production
#   [RECOMMENDED] — Core features degrade or run in stub-mode without these
#   [OPTIONAL]    — Feature-flagged; explicit opt-in
#   [LEGACY]      — Documented but slated for removal — do NOT add to new envs
# =============================================================================


# =============================================================================
# === [REQUIRED] DATABASE — Supabase Postgres ================================
# =============================================================================
# BORJIE needs ITS OWN Supabase project (NOT LITFIN's) for tenant isolation.
# `pnpm setup-env` creates one and fills these in automatically. Manual recipe:
#   1. https://supabase.com/dashboard/new → name "borjie-dev"
#   2. Settings → API → copy URL, anon key, service_role key
#   3. Settings → API → JWT Settings → copy JWT Secret
# Production uses the Supabase pooler URL (Settings → Database → Connection pooling).

# Primary database connection (Supabase pooler URL in production)
DATABASE_URL=postgresql://postgres.TODO_BORJIE_SUPABASE_PROJECT:TODO_BORJIE_DB_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
# Read-replica URL (optional; falls back to DATABASE_URL when unset)
DATABASE_URL_READONLY=
# Server-only Supabase URL (consumed by api-gateway middleware + decision-trace pages)
SUPABASE_URL=https://TODO_BORJIE_SUPABASE_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://TODO_BORJIE_SUPABASE_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TODO_BORJIE_SUPABASE_ANON_KEY
# !!!! SERVER-ONLY — bypasses ALL RLS. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=TODO_BORJIE_SUPABASE_SERVICE_ROLE_KEY
# SUPABASE_JWT_SECRET — see Docs/OPS/LIVE_TEST_RUNBOOK.md "JWT secret choice".
# For local synthetic testing: any `openssl rand -base64 48` value (.env.local).
# For browser sign-in: the Supabase Dashboard JWT Secret (HS256 projects only).
# Prod: refuses to boot without a real value.
SUPABASE_JWT_SECRET=TODO_BORJIE_SUPABASE_JWT_SECRET
# supabase-cli operator token (different from access-token-key below)
SUPABASE_ACCESS_TOKEN=
SUPABASE_ACCESS_TOKEN_KEY=TODO_BORJIE_SUPABASE_ACCESS_TOKEN
SUPABASE_ORG_ID=
# Physical-bucket env prefix used by `@borjie/storage-adapter`.
# When unset, the wiring falls back to NODE_ENV, then 'development'.
SUPABASE_ENVIRONMENT=development


# =============================================================================
# === [REQUIRED] AUTH / JWT / SESSION ========================================
# =============================================================================
# Auto-generated by `pnpm setup-env` / `pnpm gen-secrets`.
# Rotate every 90 days. See Docs/RUNBOOKS/encryption-at-rest-key-rotation.md.

# Auth router — 'supabase' in production, 'legacy' for migration window
AUTH_PROVIDER=legacy
# HS256 access-token secret (≥32 chars)
JWT_SECRET=TODO_BORJIE_GENERATE_openssl_rand_base64_48
# Service-to-service RS256 (manual generation; see runbook)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=TODO_BORJIE_GENERATE_openssl_rand_base64_48
JWT_AUDIENCE=borjie
JWT_ISSUER=borjie-api
JWT_EXPIRES_IN=15m
# Audit hash-chain (REQUIRED in production)
# Powers packages/ai-copilot/src/security/audit-hash-chain.ts.
SESSION_HASH_SECRET=TODO_BORJIE_GENERATE_openssl_rand_base64_48
SESSION_HASH_SECRET_PREV=                  # rotation-overlap slot
# Audit-trail HMAC signing root
AUDIT_TRAIL_SIGNING_SECRET=TODO_BORJIE_GENERATE_openssl_rand_base64_32
# Borjie public sign-in cookie secret (AES-256-GCM, ≥16 chars). Used by
# /api/v1/auth/sign-in to encrypt the access/refresh token pair into
# the HttpOnly `borjie-session` cookie. Rotate with the same cadence
# as SESSION_HASH_SECRET (90 days).
COOKIE_SECRET=TODO_BORJIE_GENERATE_openssl_rand_base64_48


# =============================================================================
# === [REQUIRED] ENCRYPTION-AT-REST ==========================================
# =============================================================================
# Auto-generated by `pnpm setup-env`. See Docs/RUNBOOKS/encryption-at-rest-key-rotation.md.
# Rotation cadence: 180 days; rotation overlap window: 30 days.

ENCRYPTION_MASTER_KEY=TODO_BORJIE_GENERATE_openssl_rand_base64_32
ENCRYPTION_MASTER_KEY_PREVIOUS=            # set during rotation overlap window only
ENCRYPTION_KEY_VERSION=1                   # bump on every rotation
# PII hash salt — [PRODUCTION-ONLY] REQUIRED. openssl rand -base64 32
USER_HASH_SALT=
# Next.js server actions encryption key
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=


