LME_API_BASE=https://api.lme.com/v1
LME_API_KEY=
KITCO_API_BASE=https://api.kitco.com/v1
KITCO_API_KEY=

# --- Fingerprint / biometric provider (Innovatrics / Suprema) ---------------
BIOMETRIC_PROVIDER=mock                       # mock|innovatrics|suprema
INNOVATRICS_API_KEY=
SUPREMA_API_KEY=

# --- Geo / Mapbox for portfolio map (O-W-05) --------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN=
MAPBOX_SERVER_TOKEN=

# --- Apache AGE graph extension (MVP1 graph backend) ------------------------
# Neo4j Aura slots in at MVP4+ via existing graph package.
AGE_GRAPH_ENABLED=true
AGE_GRAPH_NAME=borjie_lmbm

# --- Dev test users (seeded by scripts/seed-test-users.ts) ------------------
# DEV-ONLY: never set these in production envs.
SEED_TEST_USERS=true                          # set 'false' to skip
SEED_TEST_TENANT_ID=borjie-demo
SEED_TEST_TENANT_NAME=Mawe Bora Mining Ltd
SEED_TEST_BORJIE_ADMIN_EMAIL=admin@borjie.dev
SEED_TEST_BORJIE_ADMIN_PASSWORD=borjie-admin-dev
SEED_TEST_OWNER_EMAIL=owner@borjie.dev
SEED_TEST_OWNER_PASSWORD=owner-dev
SEED_TEST_MANAGER_EMAIL=manager@borjie.dev
SEED_TEST_MANAGER_PASSWORD=manager-dev
SEED_TEST_EMPLOYEE_EMAIL=employee@borjie.dev
SEED_TEST_EMPLOYEE_PASSWORD=employee-dev
SEED_TEST_BUYER_EMAIL=buyer@borjie.dev
SEED_TEST_BUYER_PASSWORD=buyer-dev

# --- LLM budget governor (per-tenant monthly Anthropic spend cap, USD) ------
LLM_BUDGET_DEFAULT_USD_PER_TENANT_MONTH=200
LLM_BUDGET_HARD_STOP_USD_PER_TENANT_MONTH=500


# =============================================================================
# === LEGACY / deprecated (remove after wave-M) ==============================
# =============================================================================
# These vars are still read by code paths we are migrating off. Keep set
# while consumers exist; remove from production env once the wave-M
# cleanup PR lands.

# Africa's Talking legacy aliases (prefer AFRICAS_TALKING_*)
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=
AT_ENVIRONMENT=sandbox

# Clerk auth (we migrated to Supabase Auth — see ADR 0004)
CLERK_SECRET_KEY=

# Firebase (we migrated off — vestigial in legacy customer-app code path)
FIREBASE_PROJECT_ID=

# Flutterwave (legacy regional payment provider — superseded by direct mobile-money)
FLUTTERWAVE_SECRET_KEY=

# Twilio auth-token alias for legacy notification webhook verifier (use TWILIO_AUTH_TOKEN)
# (no separate var — re-uses TWILIO_AUTH_TOKEN from RECOMMENDED section)
