# =============================================================================
# === [REQUIRED] RUNTIME =====================================================
# =============================================================================

# Platform usually injects HOST/PORT; explicit defaults shown for self-hosted.
HOST=0.0.0.0
NODE_ENV=development                       # development|test|production
LOG_LEVEL=info                             # trace|debug|info|warn|error|fatal
PORT=8080


# =============================================================================
# === [PENDING WIRING] FOUNDER-LOCKED RUNTIME GATES ==========================
# =============================================================================
# These keys are required by the production launch brief (FOUNDER_LOCKED
# decisions + production-grade hygiene) but are NOT yet read by code.
# Tracked in Docs/QA/PROD_ENV_READINESS_2026_05_27.md §3. Wiring is scheduled
# for the pre-launch wave — each TODO_PRELAUNCH marker is searched by the
# wave runner. Setting these in env today is a no-op.

# TODO_PRELAUNCH: master live-mode gate (=strict in prod)
BORJIE_LIVE_MODE=
# TODO_PRELAUNCH: PII redaction salt (KMS-backed)
BORJIE_REDACT_SALT=
# TODO_PRELAUNCH: KMS key-encryption-key ID reference
BORJIE_KEK_ID=
# TODO_PRELAUNCH: cross-tenant request gate (=true in prod)
TENANT_ISOLATION_GATE_STRICT=
# TODO_PRELAUNCH: jurisdiction profile loader default (=tz at launch)
DEFAULT_JURISDICTION_PROFILE=
# TODO_PRELAUNCH: vertical profile loader default (=mining-tz at launch)
DEFAULT_VERTICAL_PROFILE=
# TODO_PRELAUNCH: voice ambient-listening opt-in gate (=false default, opt-in per FOUNDER_LOCKED #4)
AMBIENT_LISTENING_ENABLED=
# TODO_PRELAUNCH: quiet-hours env override (defaults 18:00 / 06:00 per FOUNDER_LOCKED #1)
QUIET_HOURS_START=
QUIET_HOURS_END=


# =============================================================================
# === [RECOMMENDED] AI PROVIDERS =============================================
# =============================================================================
# Cascade: Claude → OpenAI → DeepSeek. Rotation: 365 days or per-provider policy.
# Provider keys (Anthropic, OpenAI, DeepSeek, ElevenLabs, Resend, Stripe sandbox,
# Twilio sandbox, Hume, Azure speech) are typically SHARED with LITFIN in dev
# (product-agnostic sandbox keys). Production gets its own — see
# Docs/RUNBOOKS/supabase-bootstrap.md § Production.

# Provider selection
AI_PROVIDER=anthropic
# Master kill-switch — set 'true' to halt ALL outbound LLM calls (incident response)
BORJIE_AI_KILL_SWITCH=

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=                        # optional endpoint override
CLAUDE_MODEL_DEFAULT=claude-sonnet-4-6-20260217
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
CLAUDE_MODEL_PREMIUM=claude-opus-4-6-20260210

