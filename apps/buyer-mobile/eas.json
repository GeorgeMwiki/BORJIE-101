{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "20.18.0",
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "buyer"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_API_GATEWAY_URL": "https://dev.api.borjie.example",
        "EXPO_PUBLIC_USE_LIVE_API": "false",
        "EXPO_PUBLIC_ENV": "development"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "ios": {
        "simulator": true,
        "buildConfiguration": "Debug"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_GATEWAY_URL": "https://staging.api.borjie.example",
        "EXPO_PUBLIC_USE_LIVE_API": "true",
        "EXPO_PUBLIC_ENV": "staging"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false,
        "buildConfiguration": "Release"
      }
    },
    "production": {
      "extends": "base",
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_GATEWAY_URL": "https://api.borjie.example",
        "EXPO_PUBLIC_USE_LIVE_API": "true",
        "EXPO_PUBLIC_ENV": "production"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "buildConfiguration": "Release"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal",
        "serviceAccountKeyPath": "./secrets/google-play-service-account.json"
      },
      "ios": {
        "ascAppId": "BORJIE_BUYER_APPLE_APP_ID",
        "appleTeamId": "BORJIE_APPLE_TEAM_ID"
      }
    }
  }
}
