{
  "expo": {
    "name": "Borjie",
    "slug": "borjie-workforce",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "borjie",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#3D2B1F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.borjie.workforce"
    },
    "android": {
      "package": "com.borjie.workforce",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3D2B1F"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "splashTagline": "Borjie · Ofisi ya Mgodi"
    }
  }
}
