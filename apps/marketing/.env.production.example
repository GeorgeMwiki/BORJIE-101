# =============================================================================
# @borjie/marketing — Vercel production env vars
# =============================================================================
# Copy values into Vercel Dashboard → Project Settings → Environment Variables
# (or via `vercel env add <NAME> production` from this directory after `vc link`).
#
# DO NOT commit a populated copy of this file. Every value below must be a
# placeholder, a public URL, or a non-secret default.
#
# Schema source-of-truth: apps/marketing/src/lib/env-guard.ts +
#                          apps/marketing/src/lib/supabase/env.ts
# =============================================================================

# ---- Public (NEXT_PUBLIC_*) — inlined into client bundle at build time ------
# These ARE shipped to the browser. Never put secrets here.

# Supabase project (public anon key only — RLS-gated).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<public-anon-key>

# Marketing site canonical URL (used for OG tags + sitemap).
NEXT_PUBLIC_MARKETING_SITE_URL=https://borjie.co.tz

# API gateway public URL (the chat widget calls this).
NEXT_PUBLIC_API_GATEWAY_URL=https://api.borjie.co.tz
NEXT_PUBLIC_API_BASE_URL=https://api.borjie.co.tz
NEXT_PUBLIC_API_URL=https://api.borjie.co.tz

# Owner cockpit deep-link target (for "Open your cockpit" CTAs).
NEXT_PUBLIC_OWNER_PORTAL_URL=https://owners.borjie.co.tz

# Build-time provenance for Sentry / release dashboards.
NEXT_PUBLIC_GIT_SHA=                       # Vercel populates: $VERCEL_GIT_COMMIT_SHA
NEXT_PUBLIC_SENTRY_DSN=                    # Optional — leave empty to disable.
NEXT_PUBLIC_BORJIE_PILOT_MODE=true         # `true` enables the pilot banner.

# ---- Server-only (NEVER expose to client) -----------------------------------
# This app currently has no server-only secrets — it's a public marketing site.
# If you add ISR / server actions that need a service role key, document it here.

NODE_ENV=production
