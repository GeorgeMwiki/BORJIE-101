# =============================================================================
# BORJIE — docker-compose environment file
# =============================================================================
# Copy this file to `.env.docker` and adjust values to match your
# environment. `docker compose --env-file .env.docker up` will read it.
#
# IMPORTANT — never commit real secrets. `.env.docker` is gitignored.
# =============================================================================

# ---- Postgres -----------------------------------------------------------------
POSTGRES_USER=borjie
POSTGRES_PASSWORD=borjie_dev
POSTGRES_DB=borjie
POSTGRES_PORT=5432

# ---- Redis -------------------------------------------------------------------
REDIS_PORT=6379

# ---- Neo4j -------------------------------------------------------------------
NEO4J_USER=neo4j
NEO4J_PASSWORD=borjie_graph_dev
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ---- API Gateway -------------------------------------------------------------
# Host port that maps to api-gateway:4000. Default 4001 matches the OpenAPI
# `servers` entry (see Docs/api/openapi.generated.json).
API_GATEWAY_HOST_PORT=4001
API_GATEWAY_CONTAINER_PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# JWT signing secret. MUST be overridden in staging/prod.
JWT_SECRET=change-me-in-production-please
JWT_REFRESH_SECRET=change-me-refresh-secret

# Audit hash-chain HMAC root — REQUIRED in production. Without it the chain
# silently degrades to unkeyed SHA-256 (forge-able by anyone with DB write
# access). Generate: openssl rand -base64 48. See Docs/SECRETS_ROTATION.md.
SESSION_HASH_SECRET=change-me-audit-hash-chain-root-32b-min
SESSION_HASH_SECRET_PREV=

# ---- Nginx reverse proxy -----------------------------------------------------
NGINX_HTTP_PORT=8080

# ---- Webhook delivery --------------------------------------------------------
# Default HMAC secret used when a tenant webhook has no override.
WEBHOOK_DEFAULT_HMAC_SECRET=change-me-webhook-secret
