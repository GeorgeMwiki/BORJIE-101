{
  "name": "@borjie/optimistic-concurrency",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "Optimistic concurrency primitives: ETag/If-Match preconditions + version-column retries. LITFIN-parity item 2: prevents lost updates when multiple users edit the same lease/tenant/payment. Closes P64-audit concern #2.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@borjie/audit-hash-chain": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "@types/node": "^25.8.0"
  }
}
