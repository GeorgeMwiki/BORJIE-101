{
  "name": "@borjie/dynamic-ui",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "Anticipatory UX Layer 1-2-3 — Tab Recipe registry, dynamic FormSchema composer, brand-token runtime validator. Mr. Mwikila's dynamic-UI authoring surface as defined in Docs/DESIGN/ANTICIPATORY_UX_SPEC.md.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@borjie/ai-copilot": "workspace:*",
    "@borjie/audit-hash-chain": "workspace:*",
    "@borjie/design-system": "workspace:*",
    "@borjie/genui": "workspace:*",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsup": "^8.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
