{
  "name": "@borjie/supabase-client",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "Typed Supabase wrappers: admin/user/RLS-aware clients with per-request tenant-context binding, session helpers, and idempotent schema checks. Used by the api-gateway and Brain when AUTH_PROVIDER=supabase.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "@types/node": "^25.8.0"
  }
}
