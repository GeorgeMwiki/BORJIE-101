{
  "name": "@borjie/mcp",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "Deep Model Context Protocol primitives: typed wire protocol, three transports (stdio / SSE / streamable-http), server-hosting framework with tenant-scoped tools/resources/prompts, full client with capability negotiation, tool/resource discovery + namespacing, OAuth 2.1 + PKCE auth, and pre-shipped tenant-scoped domain servers (property, payments, maintenance, documents, geo). Sister to packages/mcp-server (deployable surface) and consumed by packages/agent-runtime (consumer side).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./transport": {
      "types": "./dist/transport/index.d.ts",
      "import": "./dist/transport/index.js",
      "default": "./dist/transport/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "default": "./dist/client/index.js"
    },
    "./discovery": {
      "types": "./dist/discovery/index.d.ts",
      "import": "./dist/discovery/index.js",
      "default": "./dist/discovery/index.js"
    },
    "./domain-servers": {
      "types": "./dist/domain-servers/index.d.ts",
      "import": "./dist/domain-servers/index.js",
      "default": "./dist/domain-servers/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js",
      "default": "./dist/auth/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
