{
  "name": "@borjie/document-templates",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "Document Composition Layer 1-2-3 — the 11-recipe registry, dynamic composer, brand-locked renderers (PDF/DOCX/XLSX/PPTX), citation embedding, audit-chain link, and Tier-2 approval workflow. Implements docs/DESIGN/DOCUMENT_COMPOSITION_SPEC.md.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@borjie/ai-copilot": "workspace:*",
    "@borjie/audit-hash-chain": "workspace:*",
    "@borjie/design-system": "workspace:*",
    "@borjie/document-ai": "workspace:*",
    "@borjie/document-studio": "workspace:*",
    "@borjie/report-engine": "workspace:*",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
