{
  "name": "@borjie/regulatory-tz-mining",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "Tanzania mining-regulator rule engine adapter — NEMC, Tumemadini (MC), BoT gold window, TRA tax rules, and GePG payment-gateway integration rules. Pure rule evaluation; injectable LMBM + logger ports.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "@types/node": "^25.8.0"
  },
  "peerDependencies": {
    "@borjie/database": "workspace:*",
    "@borjie/ai-copilot": "workspace:*",
    "@borjie/observability": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@borjie/database": { "optional": true },
    "@borjie/ai-copilot": { "optional": true },
    "@borjie/observability": { "optional": true }
  }
}
