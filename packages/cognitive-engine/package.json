{
  "name": "@borjie/cognitive-engine",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "Cognitive Engine — the foundation layer under all 5 atomic capabilities. Deliberate reasoning + cite-or-stay-silent grounding + calibrated uncertainty + interactive scoping + relevance pruning + adaptive ingestion. Companion to Docs/DESIGN/COGNITIVE_ENGINE_SPEC.md (Wave 18T).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
