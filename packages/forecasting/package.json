    "fast-check": "^3.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "@borjie/graph-sync": "workspace:*",
    "@borjie/domain-models": "workspace:*"
  }
