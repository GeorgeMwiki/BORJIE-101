{
  "name": "@borjie/outcomes",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "Outcome catalog and metering primitives for BORJIE outcome-as-a-service pricing — ticket-resolved, rent-collected, vacancy-filled. Pure scorers + counterfactual baseline. No I/O.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "@types/node": "^25.8.0"
  }
}
