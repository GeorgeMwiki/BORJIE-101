{
  "name": "@borjie/performance-toolkit",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "SOTA 2026 performance toolkit",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "borjie-bundle-check": "./dist/bundle-budget/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./lazy-load": {
      "types": "./dist/lazy-load/index.d.ts",
      "import": "./dist/lazy-load/index.js",
      "require": "./dist/lazy-load/index.js",
      "default": "./dist/lazy-load/index.js"
    },
    "./streaming": {
      "types": "./dist/streaming/index.d.ts",
      "import": "./dist/streaming/index.js",
      "require": "./dist/streaming/index.js",
      "default": "./dist/streaming/index.js"
    },
    "./cache": {
      "types": "./dist/cache/index.d.ts",
      "import": "./dist/cache/index.js",
      "require": "./dist/cache/index.js",
      "default": "./dist/cache/index.js"
    },
    "./bundle-budget": {
      "types": "./dist/bundle-budget/index.d.ts",
      "import": "./dist/bundle-budget/index.js",
      "require": "./dist/bundle-budget/index.js",
      "default": "./dist/bundle-budget/index.js"
    },
    "./prompt-cache": {
      "types": "./dist/prompt-cache/index.d.ts",
      "import": "./dist/prompt-cache/index.js",
      "require": "./dist/prompt-cache/index.js",
      "default": "./dist/prompt-cache/index.js"
    },
    "./perf-metrics": {
      "types": "./dist/perf-metrics/index.d.ts",
      "import": "./dist/perf-metrics/index.js",
      "require": "./dist/perf-metrics/index.js",
      "default": "./dist/perf-metrics/index.js"
    },
    "./yield-and-chunk": {
      "types": "./dist/yield-and-chunk/index.d.ts",
      "import": "./dist/yield-and-chunk/index.js",
      "require": "./dist/yield-and-chunk/index.js",
      "default": "./dist/yield-and-chunk/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "@types/node": "^25.8.0"
  }
}
