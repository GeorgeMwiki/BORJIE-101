{
  "name": "@borjie/geo-parcels",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "Piece N: walk-and-capture land areas + map-driven parcel subdivision + cross-tenant marketplace. PostGIS-backed; hash-chained activity log.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.7",
    "@types/node": "^25.8.0"
  }
}
