{
  "name": "@borjie/mutation-authority",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "Mutation authority scaffold (Wave 18S) — the WRITE side of universal MD power. Recipe registry + proposal builder + double-verify approval workflow + audited executor + rollback. Implements docs/DESIGN/MUTATION_AUTHORITY_SPEC.md.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@borjie/audit-hash-chain": "workspace:*",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
