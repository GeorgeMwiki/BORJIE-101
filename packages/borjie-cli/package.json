{
  "name": "@borjie/cli",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Borjie command-line interface — auth, chat, drafts, reminders, estate, compliance, scope, opportunities, risks, decisions, share. Built for agents.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "borjie": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "kleur": "^4.1.5",
    "open": "^10.0.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
