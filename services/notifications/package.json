{
  "name": "@borjie/notifications-service",
  "version": "1.0.0",
  "license": "MIT",
  "description": "Multi-channel notifications (SMS, Email, Push, WhatsApp) for BORJIE",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
