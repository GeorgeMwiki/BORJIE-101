    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1053.0",
    "africastalking": "^0.7.8",
    "@sendgrid/mail": "^8.1.6",
    "axios": "^1.6.7",
    "bullmq": "^5.77.3",
    "express": "^4.18.2",
    "firebase-admin": "^13.10.0",
    "form-data": "^4.0.0",
    "ioredis": "^5.10.1",
    "nodemailer": "^8.0.5",
    "twilio": "^6.0.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/nodemailer": "^8.0.0",
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
