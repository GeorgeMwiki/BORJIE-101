{
  "name": "@borjie/consolidation-worker",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "Daily ingestion worker \u2014 pulls unconsumed kernel_cot_reservoir rows and writes consolidated semantic facts.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@borjie/brain-llm-router": "workspace:*",
    "@borjie/database": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsx": "^4.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
