{
  "name": "@borjie/junior-evolution-worker",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "Wave 18V-DYNAMIC lifecycle worker — nightly promotion / locking / deprecation for spawned + tenant-authored juniors. Mirrors the shape of ui-evolution-worker. See Docs/DESIGN/JUNIOR_DYNAMIC_SPAWNING_SPEC.md §7.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@borjie/agent-platform": "workspace:*",
    "node-cron": "^3.0.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
