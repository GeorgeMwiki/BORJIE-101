{
  "name": "@borjie/outcomes-metering-service",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "Outcomes metering service — HTTP + brain-event-bus consumer that turns OutcomeEvents (lease.signed, payment.received, ticket.resolved) into billable MeteringRecords using @borjie/outcomes pure scorers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@borjie/ai-copilot": "workspace:*",
    "@borjie/observability": "workspace:*",
    "@borjie/outcomes": "workspace:*",
    "fastify": "^5.8.3",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "uuid": "^14.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
