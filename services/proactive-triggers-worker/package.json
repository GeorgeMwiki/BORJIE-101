{
  "name": "@borjie/proactive-triggers-worker",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "Hourly sweep — for every active tenant + active user, build profile+signals, compute proactive triggers, and push high-urgency triggers to the notification sink (idempotent per (userId, kind, day)).",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@borjie/user-context-store": "workspace:*",
    "@borjie/database": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsx": "^4.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
