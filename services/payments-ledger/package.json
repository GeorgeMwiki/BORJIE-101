{
  "name": "@borjie/payments-ledger-service",
  "version": "1.0.0",
  "license": "MIT",
  "description": "Payments orchestration, ledger, reconciliation, and statement services for BORJIE",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./arrears": {
      "types": "./dist/arrears/index.d.ts",
      "default": "./dist/arrears/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc 2>/dev/null || true",
    "dev": "ts-node-dev --respawn src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src",
    "migrate": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "db:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@borjie/database": "workspace:*",
    "@borjie/domain-models": "workspace:*",
    "@prisma/client": "^5.7.0",
    "bullmq": "^5.77.3",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "stripe": "^21.0.1",
    "uuid": "^14.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^25.8.0",
    "jest": "^29.7.0",
    "prisma": "^5.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
