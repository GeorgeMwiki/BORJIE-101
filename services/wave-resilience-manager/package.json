{
  "name": "@borjie/wave-resilience-manager",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "Wave 18DD — detect crashed agent waves, revive them from the last checkpoint, drive to 100%. Per AGENT_SELF_REVIVAL_SPEC.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@borjie/audit-hash-chain": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsx": "^4.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
