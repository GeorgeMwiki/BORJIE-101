# =============================================================================
# BORJIE — .env.production.example  (Phase F.6)
# =============================================================================
# Copy to `.env.production` (gitignored) and fill real values.
# Used by:   docker compose --env-file .env.production \
#                           -f docker-compose.production.yml up -d
#
# DO NOT COMMIT a populated copy. Every value here must either be a
# placeholder, a public URL, or a sane non-secret default.
#
# Schema source-of-truth: packages/config/src/schemas.ts
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info
TZ=UTC

# ---- Postgres ---------------------------------------------------------------
POSTGRES_USER=borjie_prod
POSTGRES_PASSWORD=                # REQUIRED — openssl rand -base64 32
POSTGRES_DB=borjie_prod
# DATABASE_URL is composed inside compose; for K8s use Secret + ConfigMap
DATABASE_URL=postgresql://borjie_prod:CHANGE_ME@postgres:5432/borjie_prod

# ---- Redis ------------------------------------------------------------------
REDIS_PASSWORD=                   # REQUIRED — openssl rand -base64 32
REDIS_URL=redis://:CHANGE_ME@redis:6379

# ---- Auth / JWT -------------------------------------------------------------
JWT_SECRET=                       # REQUIRED — openssl rand -base64 48 (>=32 chars)
JWT_REFRESH_SECRET=               # REQUIRED — different from JWT_SECRET
JWT_EXPIRES_IN=7d
SESSION_HASH_SECRET=              # REQUIRED — audit hash-chain HMAC root
SESSION_HASH_SECRET_PREV=         # Optional — set during rotation window
# (Clerk removed in favor of Supabase Auth — ADR-0004)

# ---- Supabase ---------------------------------------------------------------
# Browser-safe (NEXT_PUBLIC_*) values are inlined into the client bundle.
NEXT_PUBLIC_SUPABASE_URL=                 # REQUIRED — e.g. https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=            # REQUIRED — public anon key (browser-safe)
# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
# !! SERVER-ONLY SECRETS — NEVER expose to client / NEXT_PUBLIC_* / browser !!
# !! Leaking SUPABASE_SERVICE_ROLE_KEY bypasses ALL RLS — full DB compromise!!
# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
SUPABASE_SERVICE_ROLE_KEY=                # REQUIRED — server-only; bypasses RLS
SUPABASE_JWT_SECRET=                      # REQUIRED — used by api-gateway, ai-copilot, payments-ledger

# ---- AI providers -----------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
AI_PROVIDER=anthropic

# ---- Payments ---------------------------------------------------------------
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
STRIPE_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=

# ---- Notifications ----------------------------------------------------------
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=sandbox
SENDGRID_API_KEY=
FIREBASE_PROJECT_ID=

# ---- Storage / S3 -----------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=eu-west-1

# ---- URLs -------------------------------------------------------------------
API_URL=https://api.borjie.com
FRONTEND_URL=https://borjie.com
NEXT_PUBLIC_API_URL=https://api.borjie.com/api/v1
CORS_ALLOWED_ORIGINS=https://borjie.com,https://admin.borjie.com,https://owners.borjie.com,https://manage.borjie.com

# ---- Privacy / PII ----------------------------------------------------------
BORJIE_PII_EXTENDED=1
USER_HASH_SALT=                   # REQUIRED in production — openssl rand -base64 32

# ---- Webhooks ---------------------------------------------------------------
WEBHOOK_DEFAULT_HMAC_SECRET=

# ---- Observability ----------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.posthog.com
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=borjie

# ---- Consolidation worker ---------------------------------------------------
CONSOLIDATION_INTERVAL_MS=3600000

# ---- MCP servers (Nigeria connectors) ---------------------------------------
NIMC_NIVS_BASE_URL=
NIMC_NIVS_API_KEY=
FIRS_API_BASE_URL=
FIRS_API_KEY=
NGGIS_BASE_URL=
NGGIS_API_KEY=
OPAY_BASE_URL=
OPAY_MERCHANT_ID=
OPAY_PRIVATE_KEY=

# ---- TLS / Certbot ----------------------------------------------------------
CERTBOT_EMAIL=ops@borjie.com
CERTBOT_DOMAINS=borjie.com,api.borjie.com,admin.borjie.com,owners.borjie.com,manage.borjie.com

# ---- Logging / Metrics shipping --------------------------------------------
FLUENT_BIT_OUTPUT=stdout
LOKI_URL=
CLOUDWATCH_REGION=eu-west-1
CLOUDWATCH_LOG_GROUP=/borjie/prod

# =============================================================================
# Notes
# =============================================================================
# - For Kubernetes deployments, do NOT load this file directly. Instead use
#   external-secrets-operator backed by AWS Secrets Manager / Azure Key Vault.
#   See infra/k8s/base/secrets.yaml for the ExternalSecret template.
# - For self-hosted single-server, secure this file: `chmod 600 .env.production`
#   and keep it outside the repo working tree if possible.
# =============================================================================
